{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "allowImportingTsExtension": "true",
    "types": ["node", "next"],
    "baseUrl": "./src",
    "paths": {
      "@wallet-ui/react": ["node_modules/@wallet-ui/react"],
      "@/*": [
        "./*"
      ],
      "@idl/*": [
        "anchor/target/idl/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./types",
    ],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "*.ts",
    "*.tsx",
    "anchor/**/*.ts",
    "eslint.config.mjs",
    "next-env.d.ts",
    "src/**/*",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test-parser.js",
    "test/**/*.*",
    "test/**/*.ts", // ou "tests/**/*.ts" si tu as des tests TS
    "test/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tmp"
  ]
}
